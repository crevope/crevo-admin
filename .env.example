# ─── API ──────────────────────────────────────────────────────────────────────
# Use a relative path in dev so Vite proxies to the backend and auth cookies
# stay same-origin (no cross-site SameSite / CSRF issues).
# In production use the full backend URL.
# VITE_API_URL=https://crevo-backend-production-1612.up.railway.app/api
VITE_API_URL=/api
